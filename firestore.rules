rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'role', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.role == 'user'; // Users can only create themselves as 'user'
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'userId', 'customerName', 'customerEmail', 'serviceName', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status == 'pending';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if isAdmin(); // Only admins can change roles or other admin-only fields
    }

    // Services collection (Publicly readable, Admin writeable)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes', 'customerName', 'whatsapp']));
      allow delete: if isAdmin();
    }
  }
}
